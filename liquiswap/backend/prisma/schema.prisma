// LiquiSwap Database Schema
// Equatorial Trust - Mobile Currency Exchange Platform
// PostgreSQL with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MODEL
// ============================================
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  avatar    String?
  email     String?  @unique
  pinHash   String?  // Encrypted PIN for transactions
  isVerified Boolean @default(false)
  
  // KYC Fields
  idType        String?  // Passport, ID Card, Driver's License
  idNumber      String?
  idVerifiedAt  DateTime?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime?
  
  // Relations
  balances      Balance[]
  requests      ExchangeRequest[] @relation("RequestOwner")
  matches       ExchangeRequest[] @relation("RequestMatcher")
  transactions  Transaction[]
  messages      Message[]
  notifications Notification[]
  deviceTokens  DeviceToken[]
  
  // Ratings
  rating        Float    @default(5.0)
  totalRatings  Int      @default(0)
  
  @@index([phone])
  @@index([isVerified])
  @@map("users")
}

// ============================================
// BALANCE MODEL
// ============================================
model Balance {
  id        String   @id @default(uuid())
  userId    String
  type      CurrencyType
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  
  // MTN/Orange specific
  phoneNumber String?
  
  // Cash specific
  preferredLocations String[] // Array of preferred meeting locations
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, type])
  @@index([userId])
  @@map("balances")
}

// ============================================
// EXCHANGE REQUEST MODEL
// ============================================
model ExchangeRequest {
  id          String        @id @default(uuid())
  
  // What the user has
  haveType    CurrencyType
  haveAmount  Decimal       @db.Decimal(12, 2)
  
  // What the user wants
  wantType    CurrencyType
  wantAmount  Decimal       @db.Decimal(12, 2)
  
  // Exchange rate (calculated)
  exchangeRate Decimal      @db.Decimal(10, 6)
  
  // Status
  status      RequestStatus @default(PENDING)
  
  // Location (for cash exchanges)
  location    String?
  latitude    Float?
  longitude   Float?
  
  // Expiry
  expiresAt   DateTime
  
  // Relations
  ownerId     String
  owner       User          @relation("RequestOwner", fields: [ownerId], references: [id])
  
  matcherId   String?
  matcher     User?         @relation("RequestMatcher", fields: [matcherId], references: [id])
  
  transaction   Transaction?
  
  // Timestamps
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  matchedAt   DateTime?
  
  @@index([status])
  @@index([haveType, wantType])
  @@index([ownerId])
  @@index([matcherId])
  @@index([expiresAt])
  @@map("exchange_requests")
}

// ============================================
// TRANSACTION MODEL
// ============================================
model Transaction {
  id              String            @id @default(uuid())
  
  // Linked Request
  requestId       String            @unique
  request         ExchangeRequest   @relation(fields: [requestId], references: [id])
  
  // Participants
  senderId        String            // The one who initiated (owner of request)
  receiverId      String            // The one who matched
  
  // Transaction Details
  senderAmount    Decimal           @db.Decimal(12, 2)
  receiverAmount  Decimal           @db.Decimal(12, 2)
  
  // Status Flow
  status          TransactionStatus @default(PENDING)
  
  // Confirmation tracking
  senderConfirmed   Boolean @default(false)
  receiverConfirmed Boolean @default(false)
  senderConfirmedAt DateTime?
  receiverConfirmedAt DateTime?
  
  // Dispute handling
  disputed        Boolean @default(false)
  disputeReason   String?
  disputeResolvedAt DateTime?
  
  // Ratings
  senderRating    Int?    // 1-5 stars
  receiverRating  Int?
  senderReview    String?
  receiverReview  String?
  
  // Chat
  messages        Message[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("transactions")
}

// ============================================
// MESSAGE MODEL (Chat)
// ============================================
model Message {
  id              String        @id @default(uuid())
  
  transactionId   String
  transaction     Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  senderId        String
  sender          User          @relation(fields: [senderId], references: [id])
  
  content         String
  messageType     MessageType   @default(TEXT)
  
  // Media
  mediaUrl        String?
  
  // Status
  isRead          Boolean       @default(false)
  readAt          DateTime?
  
  createdAt       DateTime      @default(now())
  
  @@index([transactionId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

// ============================================
// NOTIFICATION MODEL
// ============================================
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  body      String
  
  // Deep link data
  data      Json?
  
  isRead    Boolean          @default(false)
  readAt    DateTime?
  
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ============================================
// DEVICE TOKEN MODEL (Push Notifications)
// ============================================
model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token     String   @unique
  platform  String   // ios, android
  
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}

// ============================================
// ENUMS
// ============================================
enum CurrencyType {
  MTN
  ORANGE
  CASH
}

enum RequestStatus {
  PENDING     // Waiting for match
  MATCHED     // Found a match, waiting for confirmation
  EXPIRED     // Request expired
  CANCELLED   // User cancelled
  COMPLETED   // Transaction completed
}

enum TransactionStatus {
  PENDING      // Waiting for both confirmations
  IN_PROGRESS  // One party confirmed
  COMPLETED    // Both confirmed
  DISPUTED     // Dispute raised
  CANCELLED    // Cancelled
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
  SYSTEM
}

enum NotificationType {
  MATCH_FOUND
  MESSAGE_RECEIVED
  TRANSACTION_COMPLETED
  TRANSACTION_CONFIRMED
  PRICE_ALERT
  SYSTEM
}
